---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact - Your Portfolio">
  <div class="max-w-3xl mx-auto">
    <!-- Page Header -->
    <section class="text-center mb-16">
      <h1 class="text-3xl font-bold mb-4">Let's Connect</h1>
      <p class="text-xl text-gray-600">
        I'd love to hear about your project or just have a conversation about design. 
        Here are the best ways to reach me.
      </p>
    </section>

    <!-- Contact Options -->
    <section class="grid md:grid-cols-2 gap-8 mb-16">
      <!-- Email -->
      <div class="text-center p-8 border border-gray-200 rounded-lg">
        <div class="w-12 h-12 bg-blue-100 rounded-lg mx-auto mb-4 flex items-center justify-center">
          <span class="text-blue-600 text-xl">✉</span>
        </div>
        <h2 class="text-lg font-semibold mb-2">Email</h2>
        <p class="text-gray-600 mb-4">Best for project inquiries and detailed discussions</p>
        <a href="mailto:your.email@example.com" class="text-blue-600 hover:underline">
          your.email@example.com
        </a>
      </div>

      <!-- LinkedIn -->
      <div class="text-center p-8 border border-gray-200 rounded-lg">
        <div class="w-12 h-12 bg-blue-100 rounded-lg mx-auto mb-4 flex items-center justify-center">
          <span class="text-blue-600 text-xl">💼</span>
        </div>
        <h2 class="text-lg font-semibold mb-2">LinkedIn</h2>
        <p class="text-gray-600 mb-4">Let's connect professionally</p>
        <a href="https://linkedin.com/in/yourprofile" class="text-blue-600 hover:underline">
          View Profile
        </a>
      </div>
    </section>

    <!-- Simple Contact Form (Optional) -->
    <section class="bg-gray-50 rounded-lg p-8">
      <h2 class="text-2xl font-semibold mb-6">Send a Message</h2>
      <form class="space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              placeholder="Your name"
            />
          </div>
          
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
              placeholder="your.email@example.com"
            />
          </div>
        </div>
        
        <div>
          <label for="subject" class="block text-sm font-medium text-gray-700 mb-2">Subject</label>
          <input 
            type="text" 
            id="subject" 
            name="subject" 
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="What's this about?"
          />
        </div>
        
        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message</label>
          <textarea 
            id="message" 
            name="message" 
            rows="6" 
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            placeholder="Tell me about your project or just say hello..."
          ></textarea>
        </div>
        
        <button 
          type="submit" 
          class="w-full px-6 py-3 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition-colors"
        >
          Send Message
        </button>
        
        <p class="text-sm text-gray-600 text-center">
          Note: This form needs backend setup to actually send emails. For now, use the email link above.
        </p>
      </form>
    </section>
  </div>
</BaseLayout>