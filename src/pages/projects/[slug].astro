---
// src/pages/projects/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';

// Define types for better TypeScript support
interface ProjectLink {
  label: string;
  url: string;
}

interface ProjectData {
  title: string;
  category: string;
  timeline: string;
  description: string;
  hero: string;
  problem?: string;
  process?: string;
  outcome?: string;
  images: string[];
  links: ProjectLink[];
}

type ProjectDataMap = {
  'sine-health': ProjectData;
  'stylideas': ProjectData;
  'cadence': ProjectData;
  'parametric-modelling': ProjectData;
  'hearth': ProjectData;
}

// Simple static paths that work immediately
export async function getStaticPaths() {
  return [
    { params: { slug: 'sine-health' } },
    { params: { slug: 'stylideas' } },
    { params: { slug: 'cadence' } },
    { params: { slug: 'parametric-modelling' } },
    { params: { slug: 'hearth' } },
  ];
}

const { slug } = Astro.params;

// Project order for navigation
const projectOrder = ['sine-health', 'stylideas', 'cadence', 'parametric-modelling', 'hearth'];

// Project data with consistent slugs - now properly typed
const projectData: ProjectDataMap = {
  'sine-health': {
    title: 'Sine Health',
    category: 'Physical Product Design',
    timeline: 'Ongoing • 2024',
    description: 'Self led product development of a novel wearable device leveraging heart rate monitoring and vibration feedback for biofeedback and resilience training.',
    hero: '/projects/sine-health/hero.png',
    problem: 'Existing solutions take up audio or visual sensory channels limiting how it can be used.',
    process: 'Mentored and assisted through University, developed prototypes and working models to conduct early tests with users.',
    outcome: 'Research backed product concept used to raise initial funding. Currently developing MVP.',
    images: [
      '/projects/sine-health/image-1.png',
      '/projects/sine-health/image-2.JPG',
      '/projects/sine-health/image-3.jpg',
      '/projects/sine-health/image-4.jpg',
      '/projects/sine-health/image-5.png',
    ],
    links: [
      { label: 'View Online', url: 'https://sinehealth.co.uk/' },
    ]
  },
  'stylideas': {
    title: 'Stylideas',
    category: 'Physical Product Design',
    timeline: '1 Year • 2022',
    description: 'Full-cycle design contribution to the conception and development of the Clear View portable heated mirror.',
    hero: '/projects/stylideas/hero.png',
    problem: 'Develop innovative mirror concept, capitalising on amazon mirror trends.',
    process: 'Conducted user research, developed and tested working prototypes.',
    outcome: 'Clear View mirror is now sold across many major retailors such as QVC and Boots.',
    images: [
      '/projects/stylideas/image-1.jpg',
      '/projects/stylideas/image-2.jpeg',
      '/projects/stylideas/image-3.jpg',
      '/projects/stylideas/image-4.png'
    ],
    links: [
      { label: 'View Online', url: 'https://stylpro.co.uk/products/stylpro-anti-fog-heated-bathroom-mirror' },
    ]
  },
  'cadence': {
    title: 'Cadence',
    category: 'Product Concept',
    timeline: '1 months • 2025',
    description: 'Concept development and early prototype testing for a workout timer utilising gradients of light to seamlessly divide up time - enhancing the experience for fluid movement practices.',
    hero: '/projects/cadence/hero.png',
    images: [
      '/projects/cadence/image-1.png',
      '/projects/cadence/image-2.png',
      '/projects/cadence/image-3.png',
      '/projects/cadence/image-4.jpg',
      '/projects/cadence/image-5.png',
    ],
    links: []
  },
  'parametric-modelling': {
    title: 'Parametric Modelling',
    category: 'Skill Highlight',
    timeline: 'Ongoing • 2025',
    description: 'Ongoing exploration of parametric modelling techniques, alongside applying learnings to create product concepts.',
    hero: '/projects/parametric-modelling/hero.png',
    images: [
      '/projects/parametric-modelling/image-1.png',
      '/projects/parametric-modelling/image-2.png',
      '/projects/parametric-modelling/image-3.png'
    ],
    links: []
  },
  'hearth': {
    title: 'Hearth',
    category: 'Brand Design',
    timeline: '1 Month • 2024',
    description: 'Designed branded products for small-batch manufacture as personal gifts for friends and family.',
    hero: '/projects/hearth/hero.png',
    images: [
      '/projects/hearth/image-1.png',
      '/projects/hearth/image-2.jpg',
      '/projects/hearth/image-3.jpg',
      '/projects/hearth/image-4.png'
    ],
    links: []
  },
};

// Type-safe project lookup with fallback
const validSlug = slug as keyof ProjectDataMap;
const project = projectData[validSlug] || projectData['sine-health'];

// Calculate next and previous projects
const currentIndex = projectOrder.indexOf(validSlug);
const nextIndex = (currentIndex + 1) % projectOrder.length;
const prevIndex = (currentIndex - 1 + projectOrder.length) % projectOrder.length;
const nextProject = projectData[projectOrder[nextIndex] as keyof ProjectDataMap];
const prevProject = projectData[projectOrder[prevIndex] as keyof ProjectDataMap];
const nextSlug = projectOrder[nextIndex];
const prevSlug = projectOrder[prevIndex];
---

<BaseLayout title={`${project.title} - Louis Decleyn`} description={project.description}>
  <!-- Full-Screen Hero Image -->
  <section class="hero-section">
    <img 
      src={project.hero} 
      alt={`${project.title} - Hero Image`}
      class="hero-image"
      loading="eager"
      data-gallery={validSlug}
      data-index="0"
    />
    
    <!-- Project category overlay -->
    <div class="hero-badge">
      <div class="hero-badge-content">
        <span class="hero-badge-text">{project.category}</span>
      </div>
    </div>
  </section>

  <!-- Project Info Section -->
  <section class="content-section">
    <div class="content-grid">
      <!-- Main Content -->
      <div class="content-main">
        <h1 class="text-3xl lg:text-4xl font-normal leading-tight mb-6">{project.title}</h1>
        <p class="text-lg text-gray-600 leading-relaxed">{project.description}</p>
      </div>
      
      <!-- Project Details Sidebar -->
      <div class="content-sidebar">
        <!-- Timeline -->
        <div class="detail-block">
          <h3 class="detail-label">Timeline</h3>
          <p class="detail-value">{project.timeline}</p>
        </div>
        
        <!-- Category -->
        <div class="detail-block">
          <h3 class="detail-label">Category</h3>
          <p class="detail-value">{project.category}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Grid -->
  <section class="photo-grid">
    {project.images.map((imageSrc: string, index: number) => (
      <div class="cursor-pointer">
        <div class="photo-container">
          <img 
            src={imageSrc}
            alt={`${project.title} - Process Image ${index + 1}`}
            class="photo-image hover:scale-105"
            loading="lazy"
            data-gallery={validSlug}
            data-index={index + 1}
          />
        </div>
      </div>
    ))}
  </section>

  <!-- Project Details Grid - Only show if any of the fields exist -->
  {(project.problem || project.process || project.outcome) && (
    <section class="content-section">
      <div class="details-grid">
        <!-- Problem - Only show if exists -->
        {project.problem && (
          <div>
            <h2 class="section-title">Problem</h2>
            <p class="text-gray-700 leading-relaxed">{project.problem}</p>
          </div>
        )}

        <!-- Process - Only show if exists -->
        {project.process && (
          <div>
            <h2 class="section-title">Process</h2>
            <p class="text-gray-700 leading-relaxed">{project.process}</p>
          </div>
        )}

        <!-- Outcome - Only show if exists -->
        {project.outcome && (
          <div>
            <h2 class="section-title">Outcome</h2>
            <p class="text-gray-700 leading-relaxed">{project.outcome}</p>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Project Links -->
  {project.links && project.links.length > 0 && (
    <section class="content-section">
      <h2 class="section-title">Links & Resources</h2>
      <div class="flex flex-wrap gap-4">
        {project.links.map((link: ProjectLink) => (
          <a 
            href={link.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="link-button"
          >
            <span>{link.label}</span>
            <svg class="link-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Enhanced Navigation with Next/Previous Projects -->
  <section class="content-section navigation-section">
    <div class="project-navigation">
      <!-- Back to Portfolio -->
      <a href="/" class="nav-back">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Portfolio
      </a>

      <!-- Project Navigation -->
      <div class="project-nav-buttons">
        <!-- Previous Project -->
        <a href={`/projects/${prevSlug}`} class="project-nav-button project-nav-prev">
          <svg class="project-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          <div class="project-nav-content">
            <span class="project-nav-label">Previous</span>
            <span class="project-nav-title">{prevProject.title}</span>
          </div>
        </a>

        <!-- Next Project -->
        <a href={`/projects/${nextSlug}`} class="project-nav-button project-nav-next">
          <div class="project-nav-content">
            <span class="project-nav-label">Next</span>
            <span class="project-nav-title">{nextProject.title}</span>
          </div>
          <svg class="project-nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Override main padding for full-bleed hero */
  :global(main) {
    padding: 0 !important;
  }
</style>