---
// src/pages/projects/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';

// Simple static paths that work immediately
export async function getStaticPaths() {
  return [
    { params: { slug: 'sine-health' } },
    { params: { slug: 'stylideas' } },
    { params: { slug: 'cadence' } },
    { params: { slug: 'parametric-modelling' } },
  ];
}

const { slug } = Astro.params;

// Project data with consistent slugs
const projectData = {
  'sine-health': {
    title: 'Sine Health',
    category: 'Physical Product Design',
    timeline: '1 Year • 2024',
    description: 'A comprehensive case study of designing and developing an innovative sustainable water bottle that addresses the global plastic waste crisis through thoughtful product design.',
    hero: '/projects/sine-health/hero.png',
    problem: 'The world produces over 380 billion plastic bottles annually. I wanted to design a reusable bottle that people actually want to use daily.',
    process: 'Started with user interviews, identified key barriers to reusable bottle adoption, then focused on memory prompts, easy maintenance, and desirability.',
    outcome: '94% of test users reported daily use after 2 weeks. Featured in Fast Company\'s "Most Innovative Design" list.',
    images: [
      '/projects/sine-health/image-1.png',
      '/projects/sine-health/image-2.png',
      '/projects/sine-health/image-3.jpg'
    ],
    links: [
      { label: 'View Prototype', url: '#' },
      { label: 'Download PDF', url: '#' }
    ]
  },
  'stylideas': {
    title: 'Stylideas',
    category: 'UI/UX Design',
    timeline: '4 months • 2024',
    description: 'A digital experience design project focused on user research and interface design to improve healthcare app engagement and user satisfaction.',
    hero: '/projects/stylideas/hero.png',
    problem: 'The existing healthcare app had low engagement and poor user satisfaction scores.',
    process: 'Conducted user research, created personas, redesigned information architecture, and tested iteratively.',
    outcome: 'Increased user engagement by 67% and improved satisfaction scores from 2.1 to 4.3 stars.',
    images: [
      '/projects/stylideas/image-1.jpg',
      '/projects/stylideas/image-2.jpeg',
      '/projects/stylideas/image-3.png'
    ],
    links: [
      { label: 'Live App', url: '#' },
      { label: 'Case Study PDF', url: '#' }
    ]
  },
  'cadence': {
    title: 'Cadence',
    category: 'Product Concept',
    timeline: '3 months • 2024',
    description: 'A strategic workshop series designed to foster innovation and collaboration across cross-functional teams in enterprise environments.',
    hero: '/projects/cadence/hero.png',
    problem: 'Teams were struggling with innovation processes and cross-functional collaboration.',
    process: 'Designed workshop format, facilitated sessions, gathered feedback, and iteratively improved the approach.',
    outcome: 'Improved team collaboration scores by 45% and generated 12 implemented innovation ideas.',
    images: [
      '/projects/cadence/image-1.png',
      '/projects/cadence/image-2.png',
      '/projects/cadence/image-3.png',
      '/projects/cadence/image-4.jpg'
    ],
    links: [
      { label: 'Workshop Guide', url: '#' },
      { label: 'Results Report', url: '#' }
    ]
  },
  'parametric-modelling': {
    title: 'Parametric Modelling',
    category: 'Skill Highlight',
    timeline: '8 months • 2024',
    description: 'End-to-end design of a learning platform focused on user engagement, utilizing parametric design principles and advanced modeling techniques.',
    hero: '/projects/parametric-modelling/hero.png',
    problem: 'Low engagement rates in existing learning platforms, with 70% user drop-off in first week.',
    process: 'User research, competitive analysis, prototyping, user testing, and iterative design improvements.',
    outcome: 'Increased user engagement by 85% and reduced drop-off rate to 23%.',
    images: [
      '/projects/parametric-modelling/image-1.png',
      '/projects/parametric-modelling/image-2.png',
      '/projects/parametric-modelling/image-3.png'
    ],
    links: [
      { label: 'Live Platform', url: '#' },
      { label: 'Design System', url: '#' }
    ]
  },
};

const project = projectData[slug] || projectData['sine-health'];
---

<BaseLayout title={`${project.title} - Louis Decleyn`} description={project.description}>
  <!-- Full-Screen Hero Image -->
  <section class="hero-section">
    <img 
      src={project.hero} 
      alt={`${project.title} - Hero Image`}
      class="hero-image"
      loading="eager"
    />
    
    <!-- Project category overlay -->
    <div class="hero-badge">
      <div class="hero-badge-content">
        <span class="hero-badge-text">{project.category}</span>
      </div>
    </div>
  </section>

  <!-- Spacer to ensure content starts below hero -->
  <div class="hero-spacer"></div>

  <!-- Project Info Section -->
  <section class="content-section">
    <div class="content-grid">
      <!-- Main Content -->
      <div class="content-main">
        <h1 class="project-title">{project.title}</h1>
        <p class="project-description">{project.description}</p>
      </div>
      
      <!-- Project Details Sidebar -->
      <div class="content-sidebar">
        <!-- Timeline -->
        <div class="detail-block">
          <h3 class="detail-label">Timeline</h3>
          <p class="detail-value">{project.timeline}</p>
        </div>
        
        <!-- Category -->
        <div class="detail-block">
          <h3 class="detail-label">Category</h3>
          <p class="detail-value">{project.category}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Grid -->
  <section class="photo-grid-section">
    <div class="photo-grid">
      {project.images.map((imageSrc, index) => (
        <div class="photo-grid-item" key={index}>
          <div class="photo-container">
            <img 
              src={imageSrc}
              alt={`${project.title} - Process Image ${index + 1}`}
              class="photo-image"
              loading="lazy"
            />
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Project Details Grid -->
  <section class="content-section">
    <div class="details-grid">
      <!-- Problem -->
      <div class="detail-column">
        <h2 class="section-title">Problem</h2>
        <p class="detail-text">{project.problem}</p>
      </div>

      <!-- Process -->
      <div class="detail-column">
        <h2 class="section-title">Process</h2>
        <p class="detail-text">{project.process}</p>
      </div>

      <!-- Outcome -->
      <div class="detail-column">
        <h2 class="section-title">Outcome</h2>
        <p class="detail-text">{project.outcome}</p>
      </div>
    </div>
  </section>

    <!-- Project Links -->
  {project.links && project.links.length > 0 && (
    <section class="content-section">
      <h2 class="section-title">Links & Resources</h2>
      <div class="links-container">
        {project.links.map((link) => (
          <a 
            href={link.url} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="link-button"
          >
            <span>{link.label}</span>
            <svg class="link-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Navigation -->
  <section class="content-section navigation-section">
    <div class="navigation-container">
      <a href="/" class="nav-link back-link">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Portfolio
      </a>
      
    </div>
  </section>
</BaseLayout>

<style>
  /* Global resets for edge-to-edge hero */
  body, html {
    overflow-x: hidden;
    margin: 0;
    padding: 0;
  }

  * {
    box-sizing: border-box;
  }

  /* Full-Screen Hero Section */
  .hero-section {
    position: absolute;
    top: 0rem; /* Offset BaseLayout's pt-20 padding */
    left: 50%;
    width: 100vw;
    height: 100vh;
    margin-left: -50vw;
    z-index: 1;
    overflow: hidden;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .hero-badge {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    color: white;
    z-index: 2;
  }

  .hero-badge-content {
    background-color: rgba(0, 0, 0, 0.6);
    padding: 1rem 1.5rem;
    border-radius: 0.5rem;
    backdrop-filter: blur(8px);
  }

  .hero-badge-text {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  /* Spacer to push content below hero */
  .hero-spacer {
    height: 100vh;
    position: relative;
    z-index: 2;
  }

  /* Content Section Styling */
  .content-section {
    max-width: 896px; /* Same as your current width */
    margin: 0 auto;
    padding: 0 3rem;
    margin-bottom: 6rem;
    position: relative;
    z-index: 10;
    background: white;
  }

  .content-section:first-of-type {
    padding-top: 5rem;
  }

  /* Content Grid */
  .content-grid {
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .content-grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  .content-main {
    space-y: 2rem;
  }

  /* Project title - removed redundant font-weight (handled globally) */
  .project-title {
    font-size: 2rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 1024px) {
    .project-title {
      font-size: 2rem;
    }
  }

  .project-description {
    font-size: 0.875remrem;
    color: #6b7280;
    line-height: 1.6;
  }

  .content-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .detail-block {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Detail labels - removed redundant font-weight (handled globally) */
  .detail-label {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .detail-value {
    font-size: 0.875remrem;
    color: #6b7280;
  }

  /* Photo Grid Section */
  .photo-grid-section {
    max-width: 1400px; /* Wider for photos */
    margin: 0 auto;
    padding: 0 1.5rem;
    margin-bottom: 8rem;
    position: relative;
    z-index: 10;
  }

  @media (min-width: 1200px) {
    .photo-grid-section {
      max-width: 1600px;
      padding: 0 2rem;
    }
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  .photo-grid-item {
    cursor: pointer;
  }

  .photo-container {
    position: relative;
    width: 80%;
    height: 44rem;
    margin: 0 auto;
    overflow: hidden;
    border-radius: 0;
    background-color: #f3f4f6;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  }

  .photo-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .photo-grid-item:hover .photo-image {
    transform: scale(1.1);
  }

  /* Section titles - removed redundant font-weight (handled globally) */
  .section-title {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
    color: #111827;
  }

  /* Links Section */
  .links-container {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .link-button {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border: 1px solid #d1d5db;
    border-radius: 0.5rem;
    background: white;
    color: #374151;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .link-button:hover {
    background: #f9fafb;
    border-color: #9ca3af;
  }

  .link-icon {
    width: 1rem;
    height: 1rem;
    margin-left: 0.5rem;
    transition: transform 0.2s ease;
  }

  .link-button:hover .link-icon {
    transform: translateX(0.25rem);
  }

  /* Details Grid */
  .details-grid {
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .details-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .detail-column {
    display: flex;
    flex-direction: column;
  }

  .detail-text {
    color: #374151;
    line-height: 1.6;
  }

  /* Navigation Section */
  .navigation-section {
    border-top: 1px solid #e5e7eb;
    padding-top: 3rem;
  }

  .navigation-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    color: #6b7280;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: #111827;
  }

  .back-link .nav-icon {
    width: 1.25rem;
    height: 1.25rem;
    margin-right: 0.5rem;
    transition: transform 0.2s ease;
  }

  .back-link:hover .nav-icon {
    transform: translateX(-0.25rem);
  }

  .nav-next {
    text-align: right;
  }

  .nav-label {
    color: #6b7280;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
  }
</style>