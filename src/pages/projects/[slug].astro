---
// src/pages/projects/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import Section from '../../components/ui/Section.astro';
import ContentBlocks from '../../components/ContentBlocks.astro';
import ProjectHero from '../../components/project/ProjectHero.astro';
import ProjectMeta from '../../components/project/ProjectMeta.astro';
import ProjectLinks from '../../components/project/ProjectLinks.astro';
import ProjectNavigation from '../../components/project/ProjectNavigation.astro';
import { projectOrder, getProject, getProjectNavigation } from '../../data/projects';
import type { ProjectSlug } from '../../data/types';

export async function getStaticPaths() {
  return projectOrder.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;

// Get project data
const project = getProject(slug);
if (!project) {
  return Astro.redirect('/404');
}

// Get navigation - convert null to undefined
const navigation = getProjectNavigation(slug);
const prevProject = navigation.prev ?? undefined;
const nextProject = navigation.next ?? undefined;
---

<BaseLayout 
  title={`${project.title} - Louis Decleyn`} 
  description={project.description}
  heroImage={project.hero}
  preloadImage={project.hero}
>
  <!-- Full-Width Hero Image -->
  <ProjectHero 
    image={project.hero}
    title={project.title}
    slug={slug}
  />

  <!-- Project Header -->
  <Container>
    <Section spacing="large">
      <div class="max-w-6xl">
        <h1 class="heading-1 mb-4">{project.title}</h1>
        
        <ProjectMeta 
          timeline={project.timeline}
          category={project.category}
          class="mb-8"
        />
        
        <!-- Two Column Layout: Description + Links -->
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8 lg:gap-12">
          <!-- Left: Description (2 columns width) -->
          <div class="lg:col-span-3">
            <p class="body-text--large">{project.description}</p>
          </div>
          
          <!-- Right: Links & Resources (1 column width) -->
          {project.links && project.links.length > 0 && (
            <div class="lg:col-span-1">
              <h3 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-primary)] mb-4">
                Links & Resources
              </h3>
              <ProjectLinks links={project.links} />
            </div>
          )}
        </div>
      </div>
    </Section>
  </Container>

  <!-- Modular Content Blocks -->
  {project.contentBlocks && (
    <ContentBlocks blocks={project.contentBlocks} />
  )}

  <!-- Navigation -->
  <Section>
    <ProjectNavigation 
      prev={prevProject}
      next={nextProject}
    />
  </Section>
</BaseLayout>