---
import BaseLayout from '../../layouts/BaseLayout.astro';

// For now, we'll use static data. Later you can pull from markdown files or a CMS
const { slug } = Astro.params;

// This is placeholder data - you'll replace with dynamic content later
const projectData = {
  'project-1': {
    title: 'Project Title 1',
    category: 'Physical Product Design',
    timeline: '6 months • 2024',
    description: 'A comprehensive case study of designing and developing a innovative physical product.',
    heroImage: '/assets/projects/project-1/hero.jpg',
    problem: 'The specific problem this project aimed to solve and why it mattered.',
    process: 'The design and development process, including research, ideation, prototyping, and testing.',
    outcome: 'The final result, impact, and key learnings from the project.',
    links: [
      { label: 'View Prototype', url: '#' },
      { label: 'Download PDF', url: '#' }
    ]
  },
  'project-2': {
    title: 'Project Title 2',
    category: 'UI/UX Design',
    timeline: '4 months • 2024',
    description: 'A digital experience design project focused on user research and interface design.',
    heroImage: '/assets/projects/project-2/hero.jpg',
    problem: 'The user experience challenge and business context.',
    process: 'Research methodology, design sprint process, and iterative development.',
    outcome: 'Metrics, user feedback, and lessons learned.',
    links: [
      { label: 'Live Site', url: '#' },
      { label: 'Case Study PDF', url: '#' }
    ]
  }
};

const project = projectData[slug] || projectData['project-1'];
---

<BaseLayout title={`${project.title} - Your Portfolio`} description={project.description}>
  <!-- Back Navigation -->
  <nav class="mb-8">
    <a href="/projects" class="text-blue-600 hover:underline">← Back to Projects</a>
  </nav>

  <!-- Hero Section -->
  <section class="mb-16">
    <div class="mb-6">
      <p class="text-gray-600 mb-2">{project.category} • {project.timeline}</p>
      <h1 class="text-4xl font-bold mb-4">{project.title}</h1>
      <p class="text-xl text-gray-700 max-w-3xl">{project.description}</p>
    </div>
    
    <!-- Hero Image Placeholder -->
    <div class="h-96 bg-gray-100 rounded-lg"></div>
  </section>

  <!-- Project Details Grid -->
  <div class="grid lg:grid-cols-3 gap-12 mb-16">
    <!-- Problem -->
    <section>
      <h2 class="text-2xl font-semibold mb-4">Problem</h2>
      <p class="text-gray-700">{project.problem}</p>
    </section>

    <!-- Process -->
    <section>
      <h2 class="text-2xl font-semibold mb-4">Process</h2>
      <p class="text-gray-700">{project.process}</p>
    </section>

    <!-- Outcome -->
    <section>
      <h2 class="text-2xl font-semibold mb-4">Outcome</h2>
      <p class="text-gray-700">{project.outcome}</p>
    </section>
  </div>

  <!-- Project Images Section -->
  <section class="mb-16">
    <h2 class="text-2xl font-semibold mb-8">Project Images</h2>
    <div class="grid md:grid-cols-2 gap-8">
      <div class="h-64 bg-gray-100 rounded-lg"></div>
      <div class="h-64 bg-gray-100 rounded-lg"></div>
      <div class="h-64 bg-gray-100 rounded-lg"></div>
      <div class="h-64 bg-gray-100 rounded-lg"></div>
    </div>
  </section>

  <!-- Key Learnings -->
  <section class="mb-16">
    <h2 class="text-2xl font-semibold mb-4">Major Learnings</h2>
    <ul class="space-y-3 text-gray-700">
      <li>• Key insight or learning from this project</li>
      <li>• Another important takeaway or skill developed</li>
      <li>• What you'd do differently next time</li>
    </ul>
  </section>

  <!-- Project Links -->
  <section class="mb-16">
    <h2 class="text-2xl font-semibold mb-4">Links & Resources</h2>
    <div class="flex gap-4">
      {project.links.map(link => (
        <a 
          href={link.url} 
          class="px-6 py-3 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </section>

  <!-- Next Project -->
  <section class="border-t border-gray-200 pt-12">
    <div class="flex justify-between items-center">
      <div>
        <p class="text-gray-600 mb-2">Next Project</p>
        <h3 class="text-xl font-semibold">Another Project Title</h3>
      </div>
      <a href="/projects/project-2" class="text-blue-600 hover:underline">View Next →</a>
    </div>
  </section>
</BaseLayout>