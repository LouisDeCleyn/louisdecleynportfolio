---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Simple static paths that work immediately
export async function getStaticPaths() {
  return [
    { params: { slug: 'sine-health' } },
    { params: { slug: 'stylideas' } },
    { params: { slug: 'cadence' } },
    { params: { slug: 'parametric-modelling' } },
    { params: { slug: 'design-thinking-workshop' } },
    { params: { slug: 'startup-brand-identity' } },
  ];
}

const { slug } = Astro.params;

// Project data with consistent slugs
const projectData = {
  'sine-health': {
    title: 'Sine Health',
    category: 'Physical Product Design',
    timeline: '1 Year • 2024',
    description: 'A comprehensive case study of designing and developing an innovative sustainable water bottle.',
    hero: '/projects/sine-health/hero.png',
    problem: 'The world produces over 380 billion plastic bottles annually. I wanted to design a reusable bottle that people actually want to use daily.',
    process: 'Started with user interviews, identified key barriers to reusable bottle adoption, then focused on memory prompts, easy maintenance, and desirability.',
    outcome: '94% of test users reported daily use after 2 weeks. Featured in Fast Company\'s "Most Innovative Design" list.',
    images: [
      '/projects/sine-health/process-1.jpg',
      '/projects/sine-health/process-2.jpg',
      '/projects/sine-health/final-result.jpg',
      '/projects/sine-health/detail-shot.jpg'
    ],
    links: [
      { label: 'View Prototype', url: '#' },
      { label: 'Download PDF', url: '#' }
    ]
  },
  'stylideas': {
    title: 'Stylideas',
    category: 'UI/UX Design',
    timeline: '4 months • 2024',
    description: 'A digital experience design project focused on user research and interface design.',
    hero: '/projects/stylideas/hero.png',
    problem: 'The existing healthcare app had low engagement and poor user satisfaction scores.',
    process: 'Conducted user research, created personas, redesigned information architecture, and tested iteratively.',
    outcome: 'Increased user engagement by 67% and improved satisfaction scores from 2.1 to 4.3 stars.',
    images: [
      '/projects/healthcare-app-redesign/wireframes.jpg',
      '/projects/healthcare-app-redesign/user-flow.jpg',
      '/projects/healthcare-app-redesign/final-design.jpg',
      '/projects/healthcare-app-redesign/mobile-views.jpg'
    ],
    links: [
      { label: 'Live App', url: '#' },
      { label: 'Case Study PDF', url: '#' }
    ]
  },
  'cadence': {
    title: 'Cadence',
    category: 'Product Concept',
    timeline: '3 months • 2024',
    description: 'A strategic workshop series designed to foster innovation and collaboration.',
    hero: '/projects/cadence/hero.png',
    problem: 'Teams were struggling with innovation processes and cross-functional collaboration.',
    process: 'Designed workshop format, facilitated sessions, gathered feedback, and iteratively improved the approach.',
    outcome: 'Improved team collaboration scores by 45% and generated 12 implemented innovation ideas.',
    images: [
      '/projects/innovation-workshop-series/workshop-1.jpg',
      '/projects/innovation-workshop-series/collaboration.jpg',
      '/projects/innovation-workshop-series/results.jpg',
      '/projects/innovation-workshop-series/feedback.jpg'
    ],
    links: [
      { label: 'Workshop Guide', url: '#' },
      { label: 'Results Report', url: '#' }
    ]
  },
  'parametric-modelling': {
    title: 'Parametric Modelling',
    category: 'Skill Highlight',
    timeline: '8 months • 2024',
    description: 'End-to-end design of a learning platform focused on user engagement.',
    hero: '/projects/parametric-modelling/hero.png',
    problem: 'Low engagement rates in existing learning platforms, with 70% user drop-off in first week.',
    process: 'User research, competitive analysis, prototyping, user testing, and iterative design improvements.',
    outcome: 'Increased user engagement by 85% and reduced drop-off rate to 23%.',
    images: [
      '/projects/learning-platform-design/user-research.jpg',
      '/projects/learning-platform-design/prototypes.jpg',
      '/projects/learning-platform-design/final-platform.jpg',
      '/projects/learning-platform-design/mobile-app.jpg'
    ],
    links: [
      { label: 'Live Platform', url: '#' },
      { label: 'Design System', url: '#' }
    ]
  },
};



const project = projectData[slug] || projectData['sustainable-water-bottle'];
---

<BaseLayout title={`${project.title} - Louis Decleyn`} description={project.description}>
  <!-- Back Navigation -->
  <nav class="mb-8">
    <a href="/" class="text-gray-500 hover:text-black transition-colors">← Back to Portfolio</a>
  </nav>

  <!-- Hero Section -->
  <section class="mb-16">
    <div class="mb-6">
      <p class="text-gray-600 mb-2">{project.category} • {project.timeline}</p>
      <h1 class="text-4xl font-bold mb-4">{project.title}</h1>
      <p class="text-xl text-gray-700 max-w-3xl">{project.description}</p>
    </div>
    
    <!-- Hero Image -->
    <img 
      src={project.hero} 
      alt={`${project.title} - Hero Image`}
      class="w-full h-96 object-cover border border-gray-200"
    />
  </section>

  <!-- Project Details Grid -->
  <div class="grid lg:grid-cols-3 gap-12 mb-16">
    <!-- Problem -->
    <section>
      <h2 class="text-2xl font-semibold mb-4">Problem</h2>
      <p class="text-gray-700">{project.problem}</p>
    </section>

    <!-- Process -->
    <section>
      <h2 class="text-2xl font-semibold mb-4">Process</h2>
      <p class="text-gray-700">{project.process}</p>
    </section>

    <!-- Outcome -->
    <section>
      <h2 class="text-2xl font-semibold mb-4">Outcome</h2>
      <p class="text-gray-700">{project.outcome}</p>
    </section>
  </div>

  <!-- Project Images Section -->
  <section class="mb-16">
    <h2 class="text-2xl font-semibold mb-8">Project Images</h2>
    <div class="grid md:grid-cols-2 gap-8">
      {project.images.map((image, index) => (
        <img 
          src={image} 
          alt={`${project.title} - Image ${index + 1}`}
          class="w-full h-64 object-cover border border-gray-200"
        />
      ))}
    </div>
  </section>

  <!-- Project Links -->
  <section class="mb-16">
    <h2 class="text-2xl font-semibold mb-4">Links & Resources</h2>
    <div class="flex gap-4">
      {project.links.map(link => (
        <a 
          href={link.url} 
          class="px-6 py-3 border border-gray-300 hover:bg-gray-50 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </section>

  <!-- Next Project -->
  <section class="border-t border-gray-200 pt-12">
    <div class="flex justify-between items-center">
      <div>
        <p class="text-gray-600 mb-2">More Work</p>
        <h3 class="text-xl font-semibold">Explore Other Projects</h3>
      </div>
      <a href="/" class="text-gray-500 hover:text-black transition-colors">View Portfolio →</a>
    </div>
  </section>
</BaseLayout>