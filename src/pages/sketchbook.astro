    alt: 'Mechanical design',
    caption: 'Mechanism exploration for rotating assembly',
    date: '2021',
    category: 'product'
  },
  // Add more sketches here
];

// Sort sketches by date (newest first)
const sorted = [...sketchesData].sort((a, b) =>
  new Date(b.date).getTime() - new Date(a.date).getTime()
);

// Interleave into 3-column order so dates read top-to-bottom across all columns.
// CSS columns fills col 1 → col 2 → col 3, so to get newest items at the top
// of every column we put sorted items 0,3,6… first, then 1,4,7…, then 2,5,8…
const COLS = 3;
const sketches: typeof sorted = [];
for (let col = 0; col < COLS; col++) {
  for (let row = 0; row * COLS + col < sorted.length; row++) {
    sketches.push(sorted[row * COLS + col]);
  }
}

---

<BaseLayout title="Sketchbook - Louis Decleyn" description="A collection of sketches, explorations, and ideas that haven't made it into full projects yet.">
  <Container>
    <!-- Page Header -->
    <Section spacing="large">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-start reveal-up">
        <h1 class="heading-1">Sketchbook</h1>
        <p class="body-text--large">
          A collection of sketches, explorations, and ideas that haven't made it into full projects yet.
          Creativity, experimentation, and the messy process of thinking through design.
        </p>
      </div>
    </Section>

    <!-- Filter Toggle -->
    <Section spacing="small">
      <div class="flex justify-center gap-4 reveal-up">
        <button 
          class="filter-btn active" 
          data-filter="product"
        >
          Product Sketches
        </button>
        
        <button 
          class="filter-btn" 
          data-filter="art"
        >
          Art
        </button>
        
      </div>
    </Section>

    <!-- Masonry Grid -->
    <Section spacing="normal">
      <div class="sketchbook-grid">
        {sketches.map((sketch, index) => (
          <div 
            class={`sketch-item reveal-stagger-${Math.min(index + 1, 10)}`}
            data-category={sketch.category}
            data-index={index}
          >
            <div class="sketch-card group relative overflow-hidden bg-[var(--card-bg)] border border-[var(--card-border)] rounded-[var(--radius-card)] hover:border-[var(--card-border-hover)] hover:shadow-[var(--shadow-card-hover)] transition-all duration-[var(--transition-normal)]">
              <!-- Image -->
              <div class="sketch-image-wrapper relative overflow-hidden">
                <Image
                  src={sketch.src}
                  alt={sketch.alt}
                  width={1200}
                  height={1200}
                  class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
                  loading={index === 0 ? 'eager' : 'lazy'}
                />
                
                <!-- Hover Overlay -->
                <div class="absolute inset-0 bg-black/0 transition-all duration-300"></div>
              </div>
              

            </div>
          </div>
        ))}
      </div>
    </Section>

  </Container>

  <!-- Load External Script -->
  <script is:inline src="/scripts/reveal.js"></script>

  <!-- Filter Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const filterBtns = document.querySelectorAll<HTMLElement>('.filter-btn');
      const sketchItems = document.querySelectorAll<HTMLElement>('.sketch-item');

      // Initialize - show only product sketches on load
      sketchItems.forEach(item => {
        const category = item.getAttribute('data-category');
        if (category !== 'product') {
          item.style.display = 'none';
          item.style.opacity = '0';
        }
      });

      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = btn.getAttribute('data-filter');

          // Update active button
          filterBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          // Filter items
          sketchItems.forEach(item => {
            const category = item.getAttribute('data-category');
            
            if (category === filter) {
              item.style.display = 'block';
              // Trigger reflow for animation
              setTimeout(() => {
                item.style.opacity = '1';
                item.style.transform = 'translateY(0)';
              }, 10);
            } else {
              item.style.opacity = '0';
              item.style.transform = 'translateY(20px)';
              setTimeout(() => {
                item.style.display = 'none';
              }, 300);
            }
          });
        });
      });
    });
  </script>
</BaseLayout>

<style>
  /* Filter buttons */
  .filter-btn {
    padding: 0.5rem 1.5rem;
    border: 2px solid var(--card-border);
    background: var(--card-bg);
    color: var(--color-text-secondary);
    border-radius: var(--radius-button);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .filter-btn:hover {
    border-color: var(--card-border-hover);
    color: var(--color-text-primary);
  }

  .filter-btn.active {
    background: var(--color-primary);
    color: var(--color-text-inverse);
    border-color: var(--color-primary);
  }

  /* Masonry grid — CSS columns so images fill natural height with equal gaps */
  .sketchbook-grid {
    columns: 1;
    column-gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .sketchbook-grid {
      columns: 2;
    }
  }

  @media (min-width: 1024px) {
    .sketchbook-grid {
      columns: 3;
    }
  }

  /* Each item sits in the column flow — break-inside prevents splitting a card across columns */
  .sketch-item {
    break-inside: avoid;
    margin-bottom: var(--space-6);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* Images maintain natural aspect ratio */
  .sketch-image-wrapper {
    position: relative;
    overflow: hidden;
  }

  .sketch-image-wrapper img {
    display: block;
    width: 100%;
    height: auto;
  }
</style>