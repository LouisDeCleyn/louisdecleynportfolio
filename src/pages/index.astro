---
import BaseLayout from '../layouts/BaseLayout.astro';

// Import the same project data from your [slug].astro file
const projectData = {
  'sine-health': {
    title: 'Sine Health',
    category: 'Physical Product Design',
    description: 'A comprehensive case study of designing and developing an innovative sustainable water bottle.',
    hero: '/projects/sine-health/hero.png'
  },
  'stylideas': {
    title: 'Stylideas',
    category: 'Physical Product Design',
    description: 'A digital experience design project focused on user research and interface design.',
    hero: '/projects/stylideas/hero.png'
  },
  'cadence': {
    title: 'Cadence',
    category: 'Product Concept',
    description: 'A strategic workshop series designed to foster innovation and collaboration.',
    hero: '/projects/cadence/hero.png'
  },
  'parametric-modelling': {
    title: 'Parametric Modelling',
    category: 'Skill Highlight',
    description: 'End-to-end design of a learning platform focused on user engagement.',
    hero: '/projects/parametric-modelling/hero.png'
  }
};

// Convert project data to array for easier mapping
const projects = Object.entries(projectData).map(([slug, data]) => ({
  slug,
  ...data
}));
---

<BaseLayout title="Louis Decleyn - Designer">
  <!-- Projects Gallery - Opens Immediately -->
  <section class="projects-section">
    <!-- Dynamic Grid - Shows Only Existing Projects -->
    <div class="project-grid">
      {projects.map((project) => (
        <article class="group">
          <a href={`/projects/${project.slug}`} class="block">
            {project.hero ? (
              <img 
                src={project.hero} 
                alt={project.title}
                class="aspect-square w-full object-cover border-4 border-[#DEDEDE] mb-4 sm:mb-5 md:mb-6 group-hover:border-gray-400 transition-all duration-200"
              />
            ) : (
              <div class="aspect-square border-2 border-gray-200 mb-4 sm:mb-5 md:mb-6 group-hover:border-gray-400 transition-all duration-200 flex items-center justify-center bg-gray-50">
                <span class="text-gray-400 text-sm font-medium">[{project.category}]</span>
              </div>
            )}
            <h2 class="text-sm sm:text-base font-normal mb-1 sm:mb-2 text-black group-hover:opacity-70 transition-opacity">{project.title}</h2>
            <p class="text-gray-500 text-xs sm:text-sm">{project.category}</p>
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- Brief About Section -->
  <section class="border-t border-gray-200 pt-24 mt-32">
    <div class="max-w-5xl mx-auto">
      <div class="grid lg:grid-cols-3 gap-20 items-start">
        <!-- About Text -->
        <div class="lg:col-span-2">
          <h2 class="text-xl font-normal mb-10 text-black">About</h2>
          <div class="space-y-8">
            <p class="text-gray-700 leading-relaxed">
              I'm a designer who works across physical products, digital experiences, and strategic initiatives. 
              My approach starts with understanding the real problem before jumping to solutions.
            </p>
            
            <p class="text-gray-700 leading-relaxed">
              Whether I'm prototyping a new product, designing a user interface, or facilitating workshops, 
              I believe good design happens when you combine human insight with creative problem-solving.
            </p>
            
            <p class="text-gray-700 leading-relaxed">
              Currently based in [Your Location], working on projects that sit at the intersection of 
              design, technology, and human behavior.
            </p>
          </div>
          
          <div class="mt-10">
            <a href="/about" class="text-gray-500 hover:text-black text-sm transition-colors">
              More about my background →
            </a>
          </div>
        </div>
        
        <!-- Profile Image -->
        <div>
          <div class="aspect-[3/4] bg-gray-100 mb-4 border border-gray-200"></div>
          <p class="text-xs text-gray-500">Louis working on a project</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>