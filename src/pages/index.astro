---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import aboutPhoto from '../assets/about-photo.jpg';

// Import the same project data from your [slug].astro file
const projectData = {
  'sine-health': {
    title: 'Sine Health',
    category: 'Physical Product Design',
    description: 'A comprehensive case study of designing and developing an innovative sustainable water bottle.',
    hero: '/projects/sine-health/hero.png'
  },
  'stylideas': {
    title: 'Stylideas',
    category: 'Physical Product Design',
    description: 'A digital experience design project focused on user research and interface design.',
    hero: '/projects/stylideas/hero.png'
  },
  'cadence': {
    title: 'Cadence',
    category: 'Product Concept',
    description: 'A strategic workshop series designed to foster innovation and collaboration.',
    hero: '/projects/cadence/hero.png'
  },
  'parametric-modelling': {
    title: 'Parametric Modelling',
    category: 'Skill Highlight',
    description: 'End-to-end design of a learning platform focused on user engagement.',
    hero: '/projects/parametric-modelling/hero.png'
  },
  'hearth': {
    title: 'Hearth',
    category: 'Brand Design',
    description: 'End-to-end design of a learning platform focused on user engagement.',
    hero: '/projects/hearth/hero.png'
  }
};

// Convert project data to array for easier mapping
const projects = Object.entries(projectData).map(([slug, data]) => ({
  slug,
  ...data
}));
---

<BaseLayout title="Louis DeCleyn - Designer">
  <!-- Projects Gallery -->
  <section class="pt-16 mb-24">
    <div class="project-grid">
      {projects.map((project) => (
        <article>
          <a href={`/projects/${project.slug}`} class="project-card group">
            {project.hero ? (
              <img 
                src={project.hero} 
                alt={project.title}
                class="project-image project-image-hover"
              />
            ) : (
              <div class="project-image flex items-center justify-center bg-gray-50">
                <span class="text-gray-400 text-sm font-medium">[{project.category}]</span>
              </div>
            )}
            <h2 class="project-title">{project.title}</h2>
            <p class="project-category">{project.category}</p>
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- About Section -->
  <section class="about-section">
    <div class="content-container">
      <div class="about-grid">
        
        <div class="order-1">
          <Image 
            src={aboutPhoto}
            alt="Louis working on a project"
            class="about-image"
            width={3000}
            height={2000}
          />
          <p class="text-xs text-gray-500 mt-3 text-center md:text-left">
            Working on a project
          </p>
        </div>
        
        <div class="order-2">
          <h2 class="about-title">About Me</h2>
          
          <p class="about-text about-text-large">
            Hello, I'm Louis, a multidisciplinary designer with an entrepreneurial mindset and a deep interest in human behaviour.
          </p>
          
          <p class="about-text">
            My work lives at the intersection of physical, digital, and visual design, shaped by curiosity and a drive to build things that matter.
            Often, I've found myself in early-stage or fast-moving environments where momentum matters. I've been lucky to learn from experienced founders and designers, building a network around the shared goal of turning ideas into reality.
          </p>
          
          <p class="about-text">
            I'm drawn to projects where I can take ownership, bring big ideas to life, and grow alongside ambitious teams.
            Working on something exciting and someone who can think like a designer and execute like a founder? I'd love to hear from you.
          </p>
          
          <a href="/about" class="about-link">
            More about my background →
          </a>
        </div>
        
      </div>
    </div>
  </section>
</BaseLayout>