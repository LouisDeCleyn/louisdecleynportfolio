---
// src/pages/index.astro
// Homepage with hero carousel
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import ProjectCard from '../components/ui/ProjectCard.astro';
import { Image } from 'astro:assets';
import aboutPhoto from '../assets/about-photo.jpg';
import { projects } from '../data/homepage-projects';

// Hero carousel images
const heroImages = [
  {
    src: '/images/hero/home-hero.jpg',
    alt: 'Design Work 1'
  },
  {
    src: '/images/hero/home-hero1.jpg',
    alt: 'Design Work 2'
  },
  {
    src: '/images/hero/home-hero2.jpg',
    alt: 'Design Work 3'
  },
  {
    src: '/images/hero/home-hero3.jpg',
    alt: 'Design Work 4'
  },
  {
    src: '/images/hero/home-hero4.jpg',
    alt: 'Design Work 4'
  },
  {
    src: '/images/hero/home-hero5.png',
    alt: 'Design Work 4'
  },
  // Add more images as needed
];
---

<BaseLayout title="Louis DeCleyn - Designer">
  <!-- Hero Carousel - Full Width -->
  <div class="hero-carousel relative w-full h-[60vh] overflow-hidden">
    <!-- Slides Container -->
    <div class="slides-container relative w-full h-full">
      {heroImages.map((image, index) => (
        <div 
          class={`hero-slide absolute inset-0 transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
          data-slide-index={index}
        >
          <img 
            src={image.src}
            alt={image.alt}
            class="w-full h-full object-cover"
          />
        </div>
      ))}
    </div>

    <!-- Navigation Dots -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2 z-10">
      {heroImages.map((_, index) => (
        <div
          class={`carousel-dot w-2 h-2 rounded-full transition-all duration-300 ${index === 0 ? 'bg-white w-6' : 'bg-white/50'}`}
          data-dot-index={index}
          aria-label={`Go to slide ${index + 1}`}
        />
      ))}
    </div>
  </div>

  <Container class="py-4">
    <!-- Projects Gallery -->
    <Section spacing="large">
      <h2 class="heading-1 mb-12">Industrial Designer specialising in insight-driven concept development, computer-aided design and prototyping.</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-[var(--spacing-compact)]">
        {projects.map((project) => (
          <ProjectCard
            title={project.title}
            category={project.category}
            hero={project.hero}
            slug={project.slug}
          />
        ))}
      </div>
    </Section>
  </Container>

  <!-- About Section - Full Width Background -->
  <Section spacing="large" background="alt">
    <Container>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
        
        <!-- Photo -->
        <div class="order-1">
          <Image 
            src={aboutPhoto}
            alt="Louis working on a project"
            class="w-full h-auto object-cover object-center block rounded-[var(--radius-card)]"
            width={3000}
            height={2000}
          />
        </div>
        
        <!-- Content -->
        <div class="order-2 flex flex-col gap-4">
          <h2 class="heading-2">About Me</h2>
          
          <p class="body-text--large">
            Hello, I'm Louis, a multidisciplinary designer with an entrepreneurial mindset and a deep interest in human behaviour.
          </p>
          
          <p class="body-text">
            My work lives at the intersection of physical, digital, and visual design, shaped by curiosity and a drive to build things that matter.
            Often, I've found myself in early-stage or fast-moving environments where momentum matters. I've been lucky to learn from experienced founders and designers, building a network around the shared goal of turning ideas into reality.
          </p>
          
          <p class="body-text">
            I'm drawn to projects where I can take ownership, bring big ideas to life, and grow alongside ambitious teams.
            Working on something exciting and need someone who can think like a designer and execute like a founder? I'd love to hear from you.
          </p>
          
          <Button href="/about" variant="primary" class="mt-4">
            More about my background
          </Button>
        </div>
        
      </div>
    </Container>
  </Section>
</BaseLayout>

<script>
  // Hero Carousel Auto-Slide
  let currentSlide = 0;
  let autoSlideInterval: ReturnType<typeof setInterval>;
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.carousel-dot');
  const slideInterval = 5000; // 5 seconds per slide

  function showSlide(index: number) {
    // Hide all slides
    slides.forEach(slide => {
      slide.classList.remove('opacity-100');
      slide.classList.add('opacity-0');
    });

    // Reset all dots
    dots.forEach(dot => {
      dot.classList.remove('bg-white', 'w-6');
      dot.classList.add('bg-white/50');
    });

    // Show current slide
    slides[index].classList.remove('opacity-0');
    slides[index].classList.add('opacity-100');

    // Highlight current dot
    dots[index].classList.remove('bg-white/50');
    dots[index].classList.add('bg-white', 'w-6');

    currentSlide = index;
  }

  function nextSlide() {
    const next = (currentSlide + 1) % slides.length;
    showSlide(next);
  }

  function startAutoSlide() {
    autoSlideInterval = setInterval(nextSlide, slideInterval);
  }

  // Initialize carousel
  function initCarousel() {
    // Start auto-sliding
    startAutoSlide();
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousel);
  } else {
    initCarousel();
  }

  // Re-initialize after navigation (for SPA-like behavior)
  document.addEventListener('astro:after-swap', initCarousel);
</script>

<style>
  .hero-carousel {
    position: relative;
  }

  .hero-slide {
    transition: opacity 1s ease-in-out;
  }

  .carousel-dot {
    transition: all 0.3s ease;
  }
</style>
