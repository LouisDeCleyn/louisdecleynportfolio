---
// src/pages/blog/[slug].astro
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import Section from '../../components/ui/Section.astro';
import Button from '../../components/ui/Button.astro';
import Tag from '../../components/ui/Tag.astro';

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const { Content } = await post.render();

// Helper function to format date
function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

// Calculate reading time
function getReadingTime(content: string) {
  const wordsPerMinute = 200;
  const words = content.trim().split(/\s+/).length;
  return Math.ceil(words / wordsPerMinute);
}

const readingTime = getReadingTime(post.body);
---

<BaseLayout title={`${post.data.title} - Louis Decleyn`} description={post.data.description}>
  <Container maxWidth="wide">
    <article class="max-w-[var(--content-wide-max-width)] mx-auto">
      <!-- Back to Blog Navigation -->
      <Section spacing="normal">
        <nav class="mb-8">
          <a 
            href="/blog" 
            class="inline-flex items-center gap-2 text-[var(--color-text-secondary)] transition-colors duration-[var(--transition-normal)] hover:text-[var(--color-text-primary)]"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to Blog
          </a>
        </nav>
      </Section>

      <!-- Article Header -->
      <Section spacing="normal">
        <header class="border-b border-[var(--color-border-light)] pb-8">
          <!-- Tags -->
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4">
              {post.data.tags.map(tag => (
                <Tag variant="subtle" size="sm">{tag}</Tag>
              ))}
            </div>
          )}
          
          <!-- Title -->
          <h1 class="text-4xl md:text-5xl font-bold text-[var(--color-text-primary)] leading-tight mb-4">
            {post.data.title}
          </h1>
          
          <!-- Description -->
          {post.data.description && (
            <p class="text-xl text-[var(--color-text-secondary)] leading-relaxed mb-6">
              {post.data.description}
            </p>
          )}
          
          <!-- Meta -->
          <div class="flex items-center gap-3 text-sm text-[var(--color-text-muted)]">
            <time datetime={post.data.publishDate.toISOString()}>
              {formatDate(post.data.publishDate)}
            </time>
            <span>•</span>
            <span>{readingTime} min read</span>
          </div>
        </header>
      </Section>

      <!-- Article Content -->
      <Section spacing="normal">
        <div class="prose">
          <Content />
        </div>
      </Section>

      <!-- Footer -->
      <Section spacing="normal">
        <footer class="text-center pt-8 border-t border-[var(--color-border-light)]">
          <p class="body-text mb-4">
            Thanks for reading! Have thoughts or questions about this post?
          </p>
          <Button href="/contact" variant="primary">
            Get in touch
          </Button>
        </footer>
      </Section>
    </article>
  </Container>
</BaseLayout>

<style>
  /* Prose styling for markdown content */
  .prose {
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-secondary);
  }

  /* Headings */
  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
    line-height: var(--line-height-snug);
  }

  .prose :global(h1) { font-size: var(--font-size-3xl); }
  .prose :global(h2) { font-size: var(--font-size-2xl); }
  .prose :global(h3) { font-size: var(--font-size-xl); }

  /* Paragraphs */
  .prose :global(p) {
    margin-bottom: var(--space-6);
  }

  /* Lists */
  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  /* Blockquotes */
  .prose :global(blockquote) {
    border-left: 4px solid var(--color-border-medium);
    background-color: var(--color-background);
    padding: var(--space-4) var(--space-6);
    margin: var(--space-8) 0;
    border-radius: var(--radius-md);
  }

  /* Code */
  .prose :global(code) {
    background-color: var(--color-background-alt);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-size: 0.875em;
    font-family: var(--font-family-mono);
  }

  .prose :global(pre) {
    background-color: var(--color-neutral-800);
    color: var(--color-neutral-100);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    overflow-x: auto;
    margin: var(--space-6) 0;
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
  }

  /* Links */
  .prose :global(a) {
    color: var(--color-link);
    text-decoration: underline;
    transition: color var(--transition-normal);
  }

  .prose :global(a:hover) {
    color: var(--color-link-hover);
  }

  /* Text formatting */
  .prose :global(strong) {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }

  .prose :global(em) {
    font-style: italic;
  }

  /* Horizontal rule */
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border-light);
    margin: var(--space-8) 0;
  }

  /* Images */
  .prose :global(img) {
    border-radius: var(--radius-md);
    margin: var(--space-6) 0;
    max-width: 100%;
    height: auto;
  }

  /* Tables */
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-6) 0;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: var(--space-3);
    border: 1px solid var(--color-border-light);
    text-align: left;
  }

  .prose :global(th) {
    background-color: var(--color-background-alt);
    font-weight: var(--font-weight-semibold);
  }
</style>