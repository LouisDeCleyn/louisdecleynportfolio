---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Sample blog data
const blogPosts = [
  {
    slug: 'history-of-armour',
    title: 'A Material History of Armour',
    description: 'Tracing the evolution of armour from organic materials to modern composites and smart materials.',
    publishDate: new Date('2022-11-25'),
    readingTime: 13,
    image: '/images/blog/armour-thumb.png'
  },
];

// Helper function to format date
function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

// Sort posts by date (newest first)
const sortedPosts = blogPosts.sort((a, b) => b.publishDate.getTime() - a.publishDate.getTime());
---

<BaseLayout title="Blog - Louis Decleyn">
  <!-- Standardized Page Header with Reveal -->
  <div class="page-container">
    <section class="page-header reveal-up">
      <h1 class="page-title">Journal</h1>
      <p class="page-subtitle">
        My thoughts, inspirations and reflections on things that peak my curiosity.
      </p>
    </section>

    <!-- Blog Posts Grid with Staggered Reveals -->
    <section class="blog-posts-section">
      <div class="blog-grid">
        {sortedPosts.map((post, index) => (
          <article class={`blog-card reveal-stagger-${Math.min(index + 1, 10)}`}>
            <a href={`/blog/${post.slug}`} class="blog-card-link">
              <!-- Blog Image -->
              <div class="blog-card-image">
                <img 
                  src={post.image} 
                  alt={post.title}
                  class="blog-image"
                />
              </div>
              
              <div class="blog-card-content">
                <!-- Title -->
                <h2 class="blog-card-title">
                  {post.title}
                </h2>
                
                <!-- Description -->
                <p class="blog-card-description">
                  {post.description}
                </p>
                
                <!-- Meta -->
                <div class="blog-card-meta">
                  <time datetime={post.publishDate.toISOString()}>
                    {formatDate(post.publishDate)}
                  </time>
                  <span>{post.readingTime} min read</span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>

    <!-- Call to Action with Final Reveal -->
    <section class="cta-section reveal-up">
      <h2 class="section-title-large">Want to discuss a project?</h2>
      <p class="page-description section-spacing">
        I'm always interested in hearing about new challenges and opportunities to create meaningful products.
      </p>
      <a href="/contact" class="cta-button">
        Get in touch
      </a>
    </section>
  </div>

  <!-- Load External Script -->
  <script is:inline src="/scripts/reveal.js"></script>
</BaseLayout>