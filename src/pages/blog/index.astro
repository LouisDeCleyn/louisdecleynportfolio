---
// src/pages/blog/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';

// Sample blog data
const blogPosts = [
  {
    slug: 'history-of-armour',
    title: 'A Material History of Armour',
    description: 'Tracing the evolution of armour from ancient organic materials to modern composites and smart materials.',
    publishDate: new Date('2022-11-25'),
    readingTime: 13,
    image: '/images/blog/armour-thumb.png'
  },

/* currently commented out until finished 
  {
    slug: 'spandrels',
    title: 'Spandrels',
    description: 'Not every feature in a product - or a biological organism - exists because it was intentionally designed or selected for.',
    publishDate: new Date('2025-07-04'),
    readingTime: 8,
    image: '/images/blog/spandrels-thumb.png'
  },
*/

];

// Helper function to format date
function formatDate(date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

// Sort posts by date (newest first)
const sortedPosts = blogPosts.sort((a, b) => b.publishDate.getTime() - a.publishDate.getTime());
---

<BaseLayout title="Blog - Louis Decleyn">
  <main class="blog-main">
    <!-- Blog Header -->
    <div class="blog-header">
      <h1 class="blog-title">Process & Thoughts</h1>
      <p class="blog-description">
        Behind-the-scenes looks at my design process, lessons learned from real projects, 
        and thoughts on creating products that actually matter to people.
      </p>
    </div>

    <!-- Blog Posts Grid -->
    <div class="blog-grid">
      {sortedPosts.map((post) => (
        <article class="blog-card">
          <a href={`/blog/${post.slug}`} class="blog-card-link">
            <!-- Blog Image -->
            <div class="blog-card-image">
              <img 
                src={post.image} 
                alt={post.title}
                class="blog-image"
              />
            </div>
            
            <div class="blog-card-content">
              <!-- Title -->
              <h2 class="blog-card-title">
                {post.title}
              </h2>
              
              <!-- Description/Summary -->
              <p class="blog-card-description">
                {post.description}
              </p>
              
              <!-- Meta -->
              <div class="blog-card-meta">
                <time datetime={post.publishDate.toISOString()}>
                  {formatDate(post.publishDate)}
                </time>
                <span>{post.readingTime} min read</span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- Call to Action -->
    <section class="blog-cta">
      <h2 class="blog-cta-title">Want to discuss a project?</h2>
      <p class="blog-cta-description">
        I'm always interested in hearing about new challenges and opportunities to create meaningful products.
      </p>
      <a href="/contact" class="blog-cta-button">
        Get in touch
      </a>
    </section>
  </main>
</BaseLayout>

<style>
  .blog-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 5vw;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .blog-header {
    margin-bottom: 4rem;
  }

  .blog-title {
    font-size: 2.5rem;
    font-weight: 500;
    color: black;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .blog-description {
    font-size: 1.125rem;
    color: rgb(75, 85, 99);
    max-width: 42rem;
    line-height: 1.6;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .blog-card {
    background: white;
    border: 2px solid #f3f4f6;
    border-radius: 2px;
    overflow: hidden;
    transition: all 0.3s ease;
    aspect-ratio: 3 / 4; /* 3:4 aspect ratio for the whole card */
    display: flex;
    flex-direction: column;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    border-color: #e5e7eb;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  }

  .blog-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* Blog Image Styles */
  .blog-card-image {
    width: 100%;
    height: 60%; /* Fixed height as percentage of card */
    overflow: hidden;
    flex-shrink: 0;
    box-sizing: border-box; /* Include padding in width calculation */
    padding: 0.75rem;
    background-color: white; /* Ensure white background for border effect */
  }

  .blog-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.3s ease;
    display: block; /* Remove any inline spacing */
  }

  .blog-card-content {
    padding: 1rem; /* Reduced padding for better fit */
    display: flex;
    flex-direction: column;
    height: 40%; /* Fixed height as remaining percentage */
    justify-content: space-between; /* Distribute content evenly */
  }

  .blog-card-title {
    font-size: 1.125rem; /* Slightly smaller */
    font-weight: 500;
    color: black;
    margin-bottom: 0.5rem;
    line-height: 1.3; /* Tighter line height */
    transition: color 0.2s ease;
  }

  .blog-card:hover .blog-card-title {
    color: rgb(102, 102, 102);
  }

  .blog-card-description {
    color: rgb(75, 85, 99);
    line-height: 1.4; /* Tighter line height */
    margin-bottom: 0.75rem;
    flex-grow: 1;
    font-size: 0.875rem; /* Smaller text to fit better */
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 3; /* Limit to 3 lines */
    -webkit-box-orient: vertical;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.75rem; /* Smaller meta text */
    color: rgb(107, 114, 128);
    padding-top: 0.5rem;
    border-top: 1px solid rgb(243, 244, 246);
    margin-top: auto;
  }

  .blog-cta {
    margin-top: 5rem;
    text-align: center;
    background-color: rgb(249, 250, 251);
    padding: 3rem;
    border: 2px solid #f3f4f6;
  }

  .blog-cta-title {
    font-size: 1.5rem;
    font-weight: 500;
    color: black;
    margin-bottom: 1rem;
  }

  .blog-cta-description {
    color: rgb(75, 85, 99);
    margin-bottom: 1.5rem;
    max-width: 28rem;
    margin-left: auto;
    margin-right: auto;
  }

  .blog-cta-button {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background-color: black;
    color: white !important; 
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .blog-cta-button:hover {
    background-color: rgb(31, 41, 55);
  }

  .blog-cta-icon {
    margin-left: 0.5rem;
    width: 1rem;
    height: 1rem;
  }

  /* Responsive font adjustments */
  @media (max-width: 768px) {
    .blog-card-title {
      font-size: 1.125rem;
    }
    
    .blog-card-description {
      font-size: 0.875rem;
    }
  }
</style>