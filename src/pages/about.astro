---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import Section from '../components/layout/Section.astro';
---

<BaseLayout title="About - Louis Decleyn">
  <Container>
    <!-- Page Header -->
    <Section>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-start reveal-up">
        <h1 class="heading-1">About Me</h1>
        <p class="body-text--large">
          Adaptable designer with a strong bias toward action and problem-solving. Proven track record across product development, user research, and strategy.
        </p>
      </div>
    </Section>

  </Container>

  

  <!-- Full-width grey timeline strip -->
  <div class="bg-[var(--color-background)]">
    <div class="max-w-[var(--container-max-width)] mx-auto px-8 md:px-10 lg:px-12">
      <!-- Experience Header -->
      <div class="pt-12 md:pt-16 pb-8 flex items-center justify-between">
        <h2 class="heading-2">Experience</h2>
        <div class="flex gap-2">
          <button id="timeline-prev" aria-label="Scroll to previous"
            class="w-9 h-9 flex items-center justify-center border border-[var(--color-border-medium)] text-[var(--color-text-secondary)] hover:border-[var(--color-border-strong)] hover:text-[var(--color-text-primary)] transition-colors duration-[var(--transition-normal)]">
            ←
          </button>
          <button id="timeline-next" aria-label="Scroll to next"
            class="w-9 h-9 flex items-center justify-center border border-[var(--color-border-medium)] text-[var(--color-text-secondary)] hover:border-[var(--color-border-strong)] hover:text-[var(--color-text-primary)] transition-colors duration-[var(--transition-normal)]">
            →
          </button>
        </div>
      </div>
    <div id="timeline-track" class="overflow-x-auto select-none pb-8" style="cursor: grab; scrollbar-width: none; -webkit-overflow-scrolling: touch;">
      <div class="relative flex min-w-max">

          <!-- Connecting line spanning all items -->
          <div class="absolute left-0 right-0 h-px bg-[var(--color-border-light)]" style="top: 12px;"></div>

          <!-- Team Consulting -->
          <div class="timeline-card relative w-[280px] pr-12 pt-10">
            <div class="absolute left-0 w-2 h-2 rounded-full bg-[var(--color-border-light)]" style="top: 8px;"></div>
            <div class="h-8 mb-4 flex items-center">
              <img src="/images/logos/team-consulting.svg" alt="Team Consulting" class="h-full w-auto object-contain" />
            </div>
            <p class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] mb-2">Jan 2026 – Present</p>
            <h3 class="text-base font-medium text-[var(--color-text-primary)] leading-snug mb-3">Team Consulting</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
              Medical device design consultancy, working across the full product development cycle from early-stage concept through to detailed design and manufacture.
            </p>
          </div>

          <!-- Innovate Design -->
          <div class="timeline-card relative w-[280px] pr-12 pt-10">
            <div class="absolute left-0 w-2 h-2 rounded-full bg-[var(--color-border-light)]" style="top: 8px;"></div>
            <div class="h-8 mb-4 flex items-center">
              <img src="/images/logos/innovate-design.svg" alt="Innovate Design" class="h-full w-auto object-contain" />
            </div>
            <p class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] mb-2">Mar 2025 – Jul 2025</p>
            <h3 class="text-base font-medium text-[var(--color-text-primary)] leading-snug mb-3">Innovate Design</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
              Delivered product design services across 35+ client projects. Turned early ideas into viable solutions, created pitch visuals, explored AI tools, and supported IP filings.
            </p>
          </div>

          <!-- Lindus Health -->
          <div class="timeline-card relative w-[280px] pr-12 pt-10">
            <div class="absolute left-0 w-2 h-2 rounded-full bg-[var(--color-border-light)]" style="top: 8px;"></div>
            <div class="h-8 mb-4 flex items-center">
              <img src="/images/logos/lindus-health.svg" alt="Lindus Health" class="h-full w-auto object-contain" />
            </div>
            <p class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] mb-2">Nov 2024 – Jan 2025</p>
            <h3 class="text-base font-medium text-[var(--color-text-primary)] leading-snug mb-3">Lindus Health</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
              Improved internal processes, built tools to speed up workflows, and supported go-to-market efforts.
            </p>
          </div>

          <!-- Freelance Designer -->
          <div class="timeline-card relative w-[280px] pr-12 pt-10">
            <div class="absolute left-0 w-2 h-2 rounded-full bg-[var(--color-border-light)]" style="top: 8px;"></div>
            <div class="h-8 mb-4"></div>
            <p class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] mb-2">2023 – 2024</p>
            <h3 class="text-base font-medium text-[var(--color-text-primary)] leading-snug mb-3">Freelance Designer</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
              Developed product visualisation and marketing assets for B2C and lifestyle-focused launches. Delivered brand-aligned illustrations, packaging designs, and digital touchpoints.
            </p>
          </div>

          <!-- Brunel University London -->
          <div class="timeline-card relative w-[280px] pr-12 pt-10">
            <div class="absolute left-0 w-2 h-2 rounded-full bg-[var(--color-border-light)]" style="top: 8px;"></div>
            <div class="h-8 mb-4 flex items-center">
              <img src="/images/logos/brunel.svg" alt="Brunel University London" class="h-full w-auto object-contain" />
            </div>
            <p class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] mb-2">2020 – 2024</p>
            <h3 class="text-base font-medium text-[var(--color-text-primary)] leading-snug mb-3">Brunel University London</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
              BA Industrial Design and Technology — First Class Honours. Studied human-centred design, rapid prototyping, CAD, and design strategy.
            </p>
          </div>

          <!-- Stylideas -->
          <div class="timeline-card relative w-[280px] pr-12 pt-10">
            <div class="absolute left-0 w-2 h-2 rounded-full bg-[var(--color-border-light)]" style="top: 8px;"></div>
            <div class="h-8 mb-4 flex items-center">
              <img src="/images/logos/stylideas.svg" alt="Stylideas" class="h-full w-auto object-contain" />
            </div>
            <p class="text-[10px] uppercase tracking-widest text-[var(--color-text-muted)] mb-2">2022 – 2023</p>
            <h3 class="text-base font-medium text-[var(--color-text-primary)] leading-snug mb-3">Stylideas</h3>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
              Designed consumer products end-to-end, from sketch to shelf. Led early design research and produced launch visuals, packaging, and strategy insights.
            </p>
          </div>

      </div>
    </div>
    </div>
  </div>

  <Container>
      <!-- Skills Section -->
      <Section>
        <h2 class="heading-2 mb-12 reveal-up">Skills & Expertise</h2>
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <!-- Design Skills -->
          <div class="reveal-delay-1">
            <ul class="list-none p-0 flex flex-col gap-3">
              <li class="text-sm text-[var(--color-text-secondary)] py-1 before:content-['•'] before:mr-2 before:text-[var(--color-text-muted)]">
                Human-Centered Design & User Research
              </li>
              <li class="text-sm text-[var(--color-text-secondary)] py-1 before:content-['•'] before:mr-2 before:text-[var(--color-text-muted)]">
                Product Design & Industrial Design
              </li>
              <li class="text-sm text-[var(--color-text-secondary)] py-1 before:content-['•'] before:mr-2 before:text-[var(--color-text-muted)]">
                UI/UX Design & Interaction Design
              </li>
              <li class="text-sm text-[var(--color-text-secondary)] py-1 before:content-['•'] before:mr-2 before:text-[var(--color-text-muted)]">
                Rapid Prototyping
              </li>
              <li class="text-sm text-[var(--color-text-secondary)] py-1 before:content-['•'] before:mr-2 before:text-[var(--color-text-muted)]">
                Electronics Integration & Arduino-based Prototyping
              </li>
            </ul>
          </div>
          
          <!-- Soft Skills -->
          <div class="reveal-delay-2">
            <ul class="list-none p-0 flex flex-col gap-3">
              <li class="text-sm text-[var(--color-text-secondary)] py-1 before:content-['•'] before:mr-2 before:text-[var(--color-text-muted)]">
                Project Management
              </li>
              <li class="text-sm text-[var(--color-text-secondary)] py-1 before:content-['•'] before:mr-2 before:text-[var(--color-text-muted)]">
                Cross-Functional Teamwork
              </li>
              <li class="text-sm text-[var(--color-text-secondary)] py-1 before:content-['•'] before:mr-2 before:text-[var(--color-text-muted)]">
                Agile & Iterative Development Processes
              </li>
              <li class="text-sm text-[var(--color-text-secondary)] py-1 before:content-['•'] before:mr-2 before:text-[var(--color-text-muted)]">
                Communication & Stakeholder Engagement
              </li>
            </ul>
          </div>
        </div>
      </Section>
    </Container>


  <!-- Load External Script -->
  <script is:inline src="/scripts/reveal.js"></script>

<script>
  function initTimeline() {
    const track   = document.getElementById('timeline-track') as HTMLElement | null;
    const prevBtn = document.getElementById('timeline-prev');
    const nextBtn = document.getElementById('timeline-next');
    if (!track) return;

    // Drag-to-scroll
    let isDragging = false;
    let startX     = 0;
    let scrollStart = 0;

    track.addEventListener('mousedown', (e) => {
      isDragging  = true;
      startX      = e.pageX - track.offsetLeft;
      scrollStart = track.scrollLeft;
      track.style.cursor = 'grabbing';
    });
    track.addEventListener('mouseup', () => {
      isDragging = false;
      track.style.cursor = 'grab';
    });
    track.addEventListener('mouseleave', () => {
      isDragging = false;
      track.style.cursor = 'grab';
    });
    track.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      const x = e.pageX - track.offsetLeft;
      track.scrollLeft = scrollStart - (x - startX) * 1.2;
    });

    // Arrow navigation — snap to the exact next/previous card boundary
    // Measure from the DOM so border-box sizing is accounted for automatically
    const firstCard = track.querySelector('.timeline-card') as HTMLElement | null;
    const CARD_W    = firstCard?.offsetWidth ?? 280;
    const CARD_N    = track.querySelectorAll('.timeline-card').length;

    prevBtn?.addEventListener('click', () => {
      // ceil with small tolerance handles floating-point scrollLeft values
      const idx = Math.ceil(track.scrollLeft / CARD_W - 0.01);
      track.scrollTo({ left: Math.max(0, (idx - 1) * CARD_W), behavior: 'smooth' });
    });
    nextBtn?.addEventListener('click', () => {
      const idx = Math.floor(track.scrollLeft / CARD_W + 0.01);
      track.scrollTo({ left: Math.min((CARD_N - 1) * CARD_W, (idx + 1) * CARD_W), behavior: 'smooth' });
    });

    // Hide arrows when all items fit without scrolling
    const btnContainer = prevBtn?.parentElement as HTMLElement | null;
    function updateArrows() {
      if (!btnContainer || !track) return;
      btnContainer.style.visibility = track.scrollWidth > track.clientWidth ? 'visible' : 'hidden';
    }
    updateArrows();
    window.addEventListener('resize', updateArrows);
  }

  initTimeline();
  document.addEventListener('astro:after-swap', initTimeline);
</script>

<style>
  #timeline-track::-webkit-scrollbar { display: none; }
</style>
</BaseLayout>