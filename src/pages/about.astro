---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About - Your Portfolio">
  <!-- Main About Section -->
  <section class="grid lg:grid-cols-2 gap-12 mb-16">
    <!-- Text Content -->
    <div>
      <h1 class="text-3xl font-bold mb-6">About Me</h1>
      <div class="prose prose-gray max-w-none">
        <p class="text-lg text-gray-700 mb-4">
          I'm a designer who believes that great design happens at the intersection of 
          human needs, technical possibilities, and business goals. My work spans from 
          tangible products you can hold to digital experiences that live in your pocket.
        </p>
        
        <p class="text-gray-700 mb-4">
          My journey started in [your background], which taught me [key insight]. 
          From there, I've worked on everything from [project type] to [project type], 
          always with a focus on understanding the real problem before jumping to solutions.
        </p>
        
        <p class="text-gray-700">
          When I'm not designing, you can find me [personal interests/hobbies]. 
          I believe that diverse experiences inform better design, and I'm always 
          curious about how things work and how they could work better.
        </p>
      </div>
    </div>
    
    <!-- Image Placeholder -->
    <div>
      <div class="h-96 bg-gray-100 rounded-lg"></div>
      <p class="text-sm text-gray-600 mt-2">Photo of you in your element</p>
    </div>
  </section>

  <!-- Skills & Expertise -->
  <section class="mb-16">
    <h2 class="text-2xl font-semibold mb-8">Skills & Expertise</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-lg font-medium mb-3">Design</h3>
        <ul class="text-gray-700 space-y-1">
          <li>User Research</li>
          <li>Product Design</li>
          <li>UI/UX Design</li>
          <li>Prototyping</li>
          <li>Design Systems</li>
        </ul>
      </div>
      
      <div>
        <h3 class="text-lg font-medium mb-3">Technical</h3>
        <ul class="text-gray-700 space-y-1">
          <li>HTML/CSS</li>
          <li>JavaScript</li>
          <li>Figma</li>
          <li>Adobe Creative Suite</li>
          <li>3D Modeling</li>
        </ul>
      </div>
      
      <div>
        <h3 class="text-lg font-medium mb-3">Strategy</h3>
        <ul class="text-gray-700 space-y-1">
          <li>Design Strategy</li>
          <li>User Testing</li>
          <li>Workshop Facilitation</li>
          <li>Cross-functional Collaboration</li>
          <li>Project Management</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Experience Timeline -->
  <section class="mb-16">
    <h2 class="text-2xl font-semibold mb-8">Experience</h2>
    <div class="space-y-8">
      <div class="border-l-2 border-gray-200 pl-6">
        <div class="text-sm text-gray-600 mb-1">2023 - Present</div>
        <h3 class="text-lg font-medium">Current Role</h3>
        <p class="text-gray-700">Company Name • Brief description of what you do and key achievements.</p>
      </div>
      
      <div class="border-l-2 border-gray-200 pl-6">
        <div class="text-sm text-gray-600 mb-1">2021 - 2023</div>
        <h3 class="text-lg font-medium">Previous Role</h3>
        <p class="text-gray-700">Company Name • Brief description of what you did and key achievements.</p>
      </div>
      
      <div class="border-l-2 border-gray-200 pl-6">
        <div class="text-sm text-gray-600 mb-1">2019 - 2021</div>
        <h3 class="text-lg font-medium">Earlier Role</h3>
        <p class="text-gray-700">Company Name • Brief description of what you did and key achievements.</p>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="bg-gray-50 rounded-lg p-8 text-center">
    <h2 class="text-2xl font-semibold mb-4">Let's Work Together</h2>
    <p class="text-gray-700 mb-6 max-w-2xl mx-auto">
      I'm always interested in new challenges and collaborations. Whether you have 
      a specific project in mind or just want to chat about design, feel free to reach out.
    </p>
    <a href="/contact" class="inline-block px-6 py-3 bg-gray-900 text-white rounded-lg hover:bg-gray-800 transition-colors">
      Get In Touch
    </a>
  </section>
</BaseLayout>
