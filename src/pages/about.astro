---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About - Your Portfolio">
  <!-- Main About Section - Photo Left, Text Right -->
  <section class="about-hero">
    <!-- Photo Container -->
    <div class="photo-container">
      <img src="/images/about/profile-main.jpg" alt="Louis Decleyn in his design studio" class="main-photo" />
      <p class="photo-caption">Photo of you in your element</p>
    </div>
    
    <!-- About Me Text -->
    <div class="about-text">
      <h1 class="main-title">About Me</h1>
      <div class="prose">
        <p class="intro-text">
          I'm a designer who believes that great design happens at the intersection of 
          human needs, technical possibilities, and business goals. My work spans from 
          tangible products you can hold to digital experiences that live in your pocket.
        </p>
        
        <p class="body-text">
          My journey started in [your background], which taught me [key insight]. 
          From there, I've worked on everything from [project type] to [project type], 
          always with a focus on understanding the real problem before jumping to solutions.
        </p>
        
        <p class="body-text">
          When I'm not designing, you can find me [personal interests/hobbies]. 
          I believe that diverse experiences inform better design, and I'm always 
          curious about how things work and how they could work better.
        </p>
      </div>
    </div>
  </section>

  <!-- Skills & Experience Section - Two Columns -->
  <section class="skills-experience">
    <!-- Skills Column -->
    <div class="skills-column">
      <h2 class="section-title">Skills & Expertise</h2>
      <div class="skills-content">
        <div class="skill-group">
          <h3 class="skill-category">Design</h3>
          <ul class="skill-list">
            <li>User Research</li>
            <li>Product Design</li>
            <li>UI/UX Design</li>
            <li>Prototyping</li>
            <li>Design Systems</li>
          </ul>
        </div>
        
        <div class="skill-group">
          <h3 class="skill-category">Technical</h3>
          <ul class="skill-list">
            <li>HTML/CSS</li>
            <li>JavaScript</li>
            <li>Figma</li>
            <li>Adobe Creative Suite</li>
            <li>3D Modeling</li>
          </ul>
        </div>
        
        <div class="skill-group">
          <h3 class="skill-category">Strategy</h3>
          <ul class="skill-list">
            <li>Design Strategy</li>
            <li>User Testing</li>
            <li>Workshop Facilitation</li>
            <li>Cross-functional Collaboration</li>
            <li>Project Management</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Experience Timeline Column -->
    <div class="experience-column">
      <h2 class="section-title">Experience</h2>
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-date">March 2025 - July 2025</div>
          <h3 class="timeline-role">Innovate Design</h3>
          <p class="timeline-description">Delivered product design across 50+ client projects. Turned early ideas into viable solutions, created pitch visuals, explored AI tools, and supported IP filings.</p>
        </div>
        
        <div class="timeline-item">
          <div class="timeline-date">November 2024 - January 2025</div>
          <h3 class="timeline-role">Lindus Health</h3>
          <p class="timeline-description">Improved internal processes, built tools to speed up workflows, and supported go-to-market efforts.</p>
        </div>
        
        <div class="timeline-item">
          <div class="timeline-date">2023 - 2024</div>
          <h3 class="timeline-role">Stylideas: Freelance</h3>
          <p class="timeline-description">Led early design research and produced launch visuals, packaging, and strategy insights.</p>
        </div>

                <div class="timeline-item">
          <div class="timeline-date">2022 - 2023</div>
          <h3 class="timeline-role">Stylideas: Placement</h3>
          <p class="timeline-description">Designed consumer products end-to-end, from sketch to shelf.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Grid Section -->
  <section class="photo-grid-section">
    <h2 class="section-title">More About Me</h2>
    <div class="photo-grid">
      <img src="/images/about/image-1.JPG" alt="Louis working on a design project" class="grid-photo" />
      <img src="/images/about/image-2.jpg" alt="Louis sketching ideas" class="grid-photo" />
      <img src="/images/about/image-3.JPG" alt="Louis traveling for inspiration" class="grid-photo" />
      <img src="/images/about/image-4.jpg" alt="Louis exploring new places" class="grid-photo" />
      <img src="/images/about/image-5.JPG" alt="Louis pursuing personal interests" class="grid-photo" />
    </div>
    <p class="grid-caption">
      Photos of me working, traveling, and exploring various interests
    </p>
  </section>

  <!-- Call to Action -->
  <section class="cta-section">
    <h2 class="cta-title">Let's Work Together</h2>
    <p class="cta-text">
      I'm always interested in new challenges and collaborations. Whether you have 
      a specific project in mind or just want to chat about design, feel free to reach out.
    </p>
    <a href="/contact" class="cta-button">
      Get In Touch
    </a>
  </section>
</BaseLayout>

<style>
  /* Main About Section - Photo Left, Text Right */
  .about-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .main-photo {
    width: 100%;
    height: 24rem;
    object-fit: cover;
    border-radius: 0.5rem;
  }

  .photo-caption {
    font-size: 0.875rem;
    color: #6b7280;
    margin-top: 0.5rem;
  }

  .main-title {
    font-size: 1.875rem;
    font-weight: bold;
    margin-bottom: 1.5rem;
  }

  .intro-text {
    font-size: 1.125rem;
    color: #374151;
    margin-bottom: 1rem;
  }

  .body-text {
    color: #374151;
    margin-bottom: 1rem;
  }

  /* Skills & Experience Section - Two Columns */
  .skills-experience {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .skills-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-category {
    font-size: 1.125rem;
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .skill-list {
    color: #374151;
    list-style: none;
    padding: 0;
  }

  .skill-list li {
    margin-bottom: 0.25rem;
  }

  /* Timeline Styles */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .timeline-item {
    border-left: 2px solid #e5e7eb;
    padding-left: 1.5rem;
    position: relative;
  }

  .timeline-date {
    font-size: 0.875rem;
    color: #6b7280;
    margin-bottom: 0.25rem;
  }

  .timeline-role {
    font-size: 1.125rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .timeline-description {
    color: #374151;
  }

  /* Photo Grid Section */
  .photo-grid-section {
    margin-bottom: 4rem;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .grid-photo {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 0.5rem;
    transition: transform 0.2s ease;
  }

  .grid-photo:hover {
    transform: scale(1.02);
  }

  .grid-caption {
    font-size: 0.875rem;
    color: #6b7280;
    text-align: center;
  }

  /* Call to Action */
  .cta-section {
    background-color: #f9fafb;
    border-radius: 0.5rem;
    padding: 2rem;
    text-align: center;
  }

  .cta-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .cta-text {
    color: #374151;
    margin-bottom: 1.5rem;
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: #111827;
    color: white;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 0.2s;
  }

  .cta-button:hover {
    background-color: #1f2937;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .about-hero,
    .skills-experience {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .photo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>