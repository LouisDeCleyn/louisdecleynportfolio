---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About - Louis Decleyn">
  <!-- Standardized Page Header -->
  <div class="page-container">
    <section class="page-header">
      <h1 class="page-title">About Me</h1>
      <p class="page-subtitle">
        Adaptable designer with a strong bias toward action and problem-solving. Proven track record across product development, strategic research, and operations.
      </p>
    </section>

    <!-- Main About Section - Photo Left, Experience Right -->
    <section class="about-hero-section">
      <!-- Photo Container -->
      <div class="about-photo-container">
        <img src="/images/about/profile-main.jpg" alt="Louis Decleyn in his design studio" class="main-photo" />
      </div>
      
      <!-- Experience Timeline -->
      <div class="about-experience-content">
        <h2 class="section-title-large mb-8">Experience</h2>
        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-date">March 2025 - July 2025</div>
            <h3 class="timeline-role">Innovate Design</h3>
            <p class="timeline-description">Delivered product design services across 35+ client projects. Turned early ideas into viable solutions, created pitch visuals, explored AI tools, and supported IP filings.</p>
          </div>
          
          <div class="timeline-item">
            <div class="timeline-date">November 2024 - January 2025</div>
            <h3 class="timeline-role">Lindus Health</h3>
            <p class="timeline-description">Improved internal processes, built tools to speed up workflows, and supported go-to-market efforts.</p>
          </div>
          
          <div class="timeline-item">
            <div class="timeline-date">2023 - 2024</div>
            <h3 class="timeline-role">Freelance Designer</h3>
            <p class="timeline-description">Developed product visualisation and marketing assets for B2C and lifestyle-focused launches. Delivered brand-aligned illustrations, packaging designs, and digital touchpoints.</p>
          </div>

          <div class="timeline-item">
            <div class="timeline-date">2022 - 2023</div>
            <h3 class="timeline-role">Stylideas</h3>
            <p class="timeline-description">Designed consumer products end-to-end, from sketch to shelf. Led early design research and produced launch visuals, packaging, and strategy insights</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="skills-section">
      <h2 class="section-title-large">Skills & Expertise</h2>
      
      <div class="skills-grid">
        <!-- Software Skills -->
        <div class="skill-group">
          <h3 class="section-title-small">Software</h3>
          <div class="software-grid">
            <div class="software-item">
              <img src="/images/software/solidworks-icon.svg" alt="SolidWorks" class="software-logo" />
              <span class="software-name">SolidWorks</span>
            </div>
            <div class="software-item">
              <img src="/images/software/rhino-icon.svg" alt="Rhino" class="software-logo" />
              <span class="software-name">Rhino</span>
            </div>
            <div class="software-item">
              <img src="/images/software/grasshopper-icon.svg" alt="Grasshopper" class="software-logo" />
              <span class="software-name">Grasshopper</span>
            </div>
            <div class="software-item">
              <img src="/images/software/keyshot-icon.svg" alt="KeyShot" class="software-logo" />
              <span class="software-name">KeyShot</span>
            </div>
            <div class="software-item">
              <img src="/images/software/photoshop-icon.svg" alt="Photoshop" class="software-logo" />
              <span class="software-name">Photoshop</span>
            </div>
            <div class="software-item">
              <img src="/images/software/illustrator-icon.svg" alt="Illustrator" class="software-logo" />
              <span class="software-name">Illustrator</span>
            </div>
            <div class="software-item">
              <img src="/images/software/indesign-icon.svg" alt="InDesign" class="software-logo" />
              <span class="software-name">InDesign</span>
            </div>
            <div class="software-item">
              <img src="/images/software/xd-icon.svg" alt="Adobe XD" class="software-logo" />
              <span class="software-name">Adobe XD</span>
            </div>
            <div class="software-item">
              <img src="/images/software/visualstudiocode-icon.svg" alt="Visual Studio Code" class="software-logo" />
              <span class="software-name">Visual Studio Code</span>
            </div>
            <div class="software-item">
              <img src="/images/software/figma-icon.svg" alt="Figma" class="software-logo" />
              <span class="software-name">Figma</span>
            </div>
          </div>
        </div>
        
        <!-- Design Skills -->
        <div class="skill-group">
          <h3 class="section-title-small">Design</h3>
          <ul class="skill-list">
            <li>Human-Centered Design & User Research</li>
            <li>Product Design & Industrial Design</li>
            <li>UI/UX Design & Interaction Design</li>
            <li>Rapid Prototyping</li>
            <li>Electronics Integration & Arduino-based Prototyping</li>
          </ul>
        </div>
        
        <!-- Soft Skills -->
        <div class="skill-group">
          <h3 class="section-title-small">Soft Skills</h3>
          <ul class="skill-list">
            <li>Project Management</li>
            <li>Cross-Functional Teamwork</li>
            <li>Agile & Iterative Development Processes</li>
            <li>Communication & Stakeholder Engagement</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Photo Grid Section -->
    <section class="photo-grid-section">
      <h2 class="section-title-large">More About Me</h2>
      <div class="about-photo-grid">
        <div class="photo-item">
          <img src="/images/about/image-1.JPG" alt="Louis working on a design project" class="grid-photo" />
          <div class="photo-overlay">
            <p class="photo-description">Collecting feedback on Prototypes at Olympia London</p>
          </div>
        </div>
        
        <div class="photo-item">
          <img src="/images/about/image-2.jpg" alt="Louis sketching ideas" class="grid-photo" />
          <div class="photo-overlay">
            <p class="photo-description">Sketching out new ideas and concepts</p>
          </div>
        </div>
        
        <div class="photo-item">
          <img src="/images/about/image-3.JPG" alt="Louis traveling for inspiration" class="grid-photo" />
          <div class="photo-overlay">
            <p class="photo-description">Competed in the 2022 BUCs Boxing</p>
          </div>
        </div>
        
        <div class="photo-item">
          <img src="/images/about/image-4.jpg" alt="Louis exploring new places" class="grid-photo" />
          <div class="photo-overlay">
            <p class="photo-description">Participating in UI/UX co-design workshop</p>
          </div>
        </div>
        
        <div class="photo-item">
          <img src="/images/about/image-5.png" alt="Louis pursuing personal interests" class="grid-photo" />
          <div class="photo-overlay">
            <p class="photo-description">Attending the 2025 Brunel University Alumni Awards</p>
          </div>
        </div>
      </div>
      <p class="text-sm text-gray-500 text-center mt-4">
        Photos of me working, traveling, and exploring various interests
      </p>
    </section>

    <!-- Call to Action -->
    <section class="cta-section">
      <h2 class="section-title-large">Let's Work Together</h2>
      <p class="text-base text-gray-700 mb-6 max-w-2xl mx-auto">
        I'm always interested in new challenges and collaborations. Whether you have 
        a specific project in mind or just want to chat about design, feel free to reach out.
      </p>
      <a href="/contact" class="cta-button">
        Get In Touch
      </a>
    </section>

  </div>
</BaseLayout>