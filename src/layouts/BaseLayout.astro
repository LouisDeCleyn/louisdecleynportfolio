---
// src/layouts/BaseLayout.astro
// REFACTORED: Now composes Navbar and Footer components
import '../styles/tokens.css';
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  preloadImage?: string;
  heroImage?: string;
  project?: string;
}

const {
  title,
  description = "Personal portfolio showcasing design work",
  ogImage,
  ogType = "website",
  preloadImage,
  heroImage,
  project
} = Astro.props;

const resolvedOgImage = ogImage ?? heroImage ?? "/og-image.JPG";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Material Symbols — loaded async so it never blocks rendering -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" as="style" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" /></noscript>

    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} />
    )}
    {heroImage && heroImage !== preloadImage && (
      <link rel="preload" as="image" href={heroImage} />
    )}
    
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={resolvedOgImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Navbar Component -->
    <Navbar />
    
    <!-- Main Content with project data attribute -->
    <main 
      class="flex-1" 
      {...(project ? { 'data-project': project } : {})}
    >
      <slot />
    </main>
    
    <!-- Footer Component -->
    <Footer />

    <!-- Custom Cursor Script -->
    <script is:inline src="/scripts/cursor.js"></script>
  </body>
</html>