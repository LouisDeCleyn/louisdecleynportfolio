---
// src/layouts/BaseLayout.astro
// REFACTORED: Now composes Navbar and Footer components
import '../styles/tokens.css';
import '../styles/global.css';
import Navbar from '../components/layout/Navbar.astro';
import Footer from '../components/layout/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  preloadImage?: string;
  heroImage?: string;
  project?: string;
}

const { 
  title, 
  description = "Personal portfolio showcasing design work",
  ogImage = "/og-image.JPG",
  ogType = "website",
  preloadImage,
  heroImage,
  project
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />

    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} />
    )}
    {heroImage && heroImage !== preloadImage && (
      <link rel="preload" as="image" href={heroImage} />
    )}
    
    <title>{title}</title>
  </head>
  <body class="flex flex-col min-h-screen">
    <!-- Navbar Component -->
    <Navbar />
    
    <!-- Main Content with project data attribute -->
    <main 
      class="flex-1" 
      {...(project ? { 'data-project': project } : {})}
    >
      <slot />
    </main>
    
    <!-- Footer Component -->
    <Footer />

    <!-- Custom Cursor Script -->
    <script is:inline src="/scripts/cursor.js"></script>
  </body>
</html>