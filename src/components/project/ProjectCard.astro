---
/**
 * ProjectCard Component
 * Full-bleed image card with hover-reveal title/category overlay
 */
import { Image } from 'astro:assets';

interface Props {
  title: string;
  category: string;
  hero?: string;
  slug: string;
  class?: string;
  loading?: 'eager' | 'lazy';
}

const {
  title,
  category,
  hero,
  slug,
  class: className = '',
  loading = 'lazy'
} = Astro.props;
---

<article class={`group relative overflow-hidden h-full ${className}`}>
  <a href={`/projects/${slug}`} class="block h-full">
    {hero ? (
      <>
        <Image
          src={hero}
          width={800}
          height={800}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
          loading={loading}
        />
        <!-- Gradient overlay — fades in on hover -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
        <!-- Text — slides up on hover -->
        <div class="absolute bottom-0 left-0 right-0 p-4 md:p-5 translate-y-2 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
          <p class="text-white/60 text-[10px] uppercase tracking-widest mb-1">{category}</p>
          <h2 class="text-white text-sm font-medium leading-snug">{title}</h2>
        </div>
      </>
    ) : (
      <div class="flex items-center justify-center h-full bg-[var(--color-background)] border border-[var(--card-border)]">
        <span class="text-[var(--color-text-subtle)] text-sm font-medium">[{category}]</span>
      </div>
    )}
  </a>
</article>
