---
// src/components/project/ProjectLinks.astro
// Displays project links and resources
import Button from '../ui/Button.astro';

interface ProjectLink {
  label: string;
  url: string;
}

interface Props {
  links: ProjectLink[];
  class?: string;
}

const { links, class: className = '' } = Astro.props;

if (!links || links.length === 0) return null;
---

<div class={`flex flex-wrap gap-3 ${className}`}>
  {links.map((link) => (
    <a 
      href={link.url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-[var(--color-text-secondary)] bg-[var(--color-background-alt)] border border-[var(--color-border-light)] rounded-[var(--radius-button)] transition-all duration-[var(--transition-normal)] hover:border-[var(--color-border-medium)] hover:bg-[var(--color-surface)] hover:text-[var(--color-text-primary)]"
    >
      <span>{link.label}</span>
      <span class="material-symbols-outlined text-base">language</span>
    </a>
  ))}
</div>

<style>
  .material-symbols-outlined {
    font-variation-settings:
    'FILL' 0,
    'wght' 400,
    'GRAD' 0,
    'opsz' 20;
  }
</style>