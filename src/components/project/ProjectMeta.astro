---
// src/components/project/ProjectMeta.astro
// Displays project metadata (timeline, category, etc.)

interface Props {
  timeline: string;
  category: string;
  role?: string;
  class?: string;
}

const { timeline, category, role, class: className = '' } = Astro.props;
---

<div class={`flex flex-wrap items-center gap-4 md:gap-6 ${className}`}>
  <!-- Timeline -->
  <div class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)]">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span>{timeline}</span>
  </div>
  
  <!-- Category -->
  <div class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)]">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
    </svg>
    <span>{category}</span>
  </div>

  <!-- Role (optional) -->
  {role && (
    <div class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)]">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      <span>{role}</span>
    </div>
  )}
</div>