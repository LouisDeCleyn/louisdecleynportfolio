---
// src/components/ui/Section.astro
// Reusable section wrapper with responsive spacing
interface Props {
  spacing?: 'small' | 'normal' | 'large' | 'none';
  background?: 'default' | 'alt' | 'none';
  class?: string;
}

const { 
  spacing = 'normal',
  background = 'none',
  class: className = ''
} = Astro.props;

// Responsive spacing: smaller on mobile, scales up on larger screens
const spacingClasses = {
  small: 'py-6 md:py-8',                                  // 24px → 32px
  normal: 'py-12 md:py-16 lg:py-[var(--spacing-section)]', // 48px → 64px → 96px
  large: 'py-16 md:py-20 lg:py-[var(--spacing-major)]',    // 64px → 80px → 128px
  none: 'py-0'
};

const backgroundClasses = {
  default: 'bg-[var(--color-surface)]',
  alt: 'bg-[var(--color-background)]',
  none: ''
};

const classes = `w-full ${spacingClasses[spacing]} ${backgroundClasses[background]} ${className}`;
---

<section class={classes}>
  <slot />
</section>